# Microsoft Entra ID / Azure AD - single-tenant Cabiran app registration
AZURE_CLIENT_ID=<your-azure-app-client-id>
AZURE_TENANT_ID=<your-cabiran-tenant-id>
AZURE_CLIENT_SECRET=<your-azure-app-client-secret>
AZURE_REDIRECT_URI=https://onenote-mcp.onrender.com/auth/callback

# Fernet key used to encrypt /data/token_cache.bin
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MSAL_CACHE_KEY=<base64-fernet-key>

# Shared secret between Claude Desktop / Claude Code and this MCP server
MCP_API_KEY=<random-secret-key>

# Server settings
BASE_URL=https://onenote-mcp.onrender.com
DATA_DIR=/data
